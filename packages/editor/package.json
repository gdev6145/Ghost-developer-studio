{
  "name": "@ghost/editor",
  "version": "0.1.0",
  "private": true,
  "description": "Monaco editor setup with Yjs collaborative bindings",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external monaco-editor",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external monaco-editor",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ghost/collaboration": "workspace:*",
    "@ghost/protocol": "workspace:*",
    "@ghost/shared": "workspace:*",
    "@ghost/state": "workspace:*",
    "y-monaco": "^0.1.5",
    "yjs": "^13.6.14"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "monaco-editor": "^0.47.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "monaco-editor": "^0.47.0",
    "react": "^18.3.0"
  }
}
