{
  "name": "@ghost/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma database client and schema for Ghost",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "prisma generate && tsup src/index.ts --format cjs,esm && tsc --emitDeclarationOnly --declaration --declarationMap false --outDir dist",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "prisma generate && tsc --noEmit",
    "lint": "prisma generate && eslint src --ext .ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@prisma/client": "^5.12.0"
  },
  "devDependencies": {
    "prisma": "^5.12.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  }
}
