# Environment variables for Ghost Developer Studio
# Copy this file to .env and fill in values

# ─── Server ─────────────────────────────────────────────────
SERVER_PORT=4000
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://ghost:ghost@localhost:5432/ghost_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── GitHub OAuth ───────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# ─── Web App ────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Docker Runtime ─────────────────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock
RUNTIME_NETWORK=ghost_runtime

# ─── Workspace Storage ──────────────────────────────────────
# Root directory where workspace git repos are stored (for terminal & git routes)
WORKSPACE_ROOT=/workspaces

# ─── AI Pair Programming ────────────────────────────────────
# Set AI_ENABLED=true and provide an API key to activate the AI agent
AI_ENABLED=false
OPENAI_API_KEY=your_openai_api_key
