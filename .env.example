# Environment variables for Ghost Developer Studio
# Copy this file to .env and fill in values

# ─── Server ─────────────────────────────────────────────────
SERVER_PORT=4000
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://ghost:ghost@localhost:5432/ghost_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── GitHub OAuth ───────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# ─── Web App ────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Docker Runtime ─────────────────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock
RUNTIME_NETWORK=ghost_runtime

# ─── AI Pair Programming ────────────────────────────────────────────────────
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Internal ───────────────────────────────────────────────────────────────
# Secret used to authenticate internal replay persist calls
INTERNAL_SECRET=change_me_internal_secret

# ─── Observability ──────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal (default: info in prod, debug in dev)
LOG_LEVEL=info

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://...@sentry.io/...

# ─── Security ───────────────────────────────────────────────────────────────
# Allowed CORS origin for production (leave unset to allow all origins in dev)
# CORS_ORIGIN=https://app.ghostdev.studio

# ─── SSO / OIDC (optional, for enterprise identity) ────────────────────────
# OIDC_ISSUER_URL=https://your-idp.example.com
# OIDC_CLIENT_ID=ghost_studio
# OIDC_CLIENT_SECRET=change_me_oidc_secret
# OIDC_REDIRECT_URI=https://app.ghostdev.studio/auth/oidc/callback

# ─── Deployment (staging / prod Docker Compose overlays) ───────────────────
# IMAGE_TAG=v1.2.3
# REGISTRY=ghcr.io/your-org
# PRODUCTION_WEB_URL=https://app.ghostdev.studio
# PRODUCTION_WS_URL=wss://api.ghostdev.studio
# PRODUCTION_API_URL=https://api.ghostdev.studio
# POSTGRES_PASSWORD=change_me_postgres_password
# REDIS_PASSWORD=change_me_redis_password
